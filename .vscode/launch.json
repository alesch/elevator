{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "mix_task",
      "name": "mix test (Active File)",
      "request": "launch",
      "task": "test",
      "taskArgs": [
        "--trace",
        "${relativeFile}"
      ],
      "projectDir": "${workspaceRoot}",
      "requireFiles": [
        "test/**/test_helper.exs",
        "test/**/*.exs"
      ]
    },
    {
      "type": "mix_task",
      "name": "mix test --only stop",
      "request": "launch",
      "task": "test",
      "taskArgs": [
        "--trace",
        "--only",
        "stop",
        "${relativeFile}"
      ],
      "projectDir": "${workspaceRoot}",
      "requireFiles": [
        "test/**/test_helper.exs",
        "test/**/*.exs"
      ]
    },
    {
      "type": "mix_task",
      "name": "mix test (All)",
      "request": "launch",
      "task": "test",
      "taskArgs": [
        "--trace"
      ],
      "projectDir": "${workspaceRoot}",
      "requireFiles": [
        "test/**/test_helper.exs",
        "test/**/*.exs"
      ]
    }
  ]
}